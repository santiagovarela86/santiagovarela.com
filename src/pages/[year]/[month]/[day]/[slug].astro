---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: {
      year: String(post.data.pubDate.getUTCFullYear()),
      month: String(post.data.pubDate.getUTCMonth() + 1).padStart(2, '0'),
      day: String(post.data.pubDate.getUTCDate()).padStart(2, '0'),
      slug: post.id,
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const email = 'santiagovarela.86@gmail.com';
const linkedInUrl = 'https://www.linkedin.com/in/santiago-v-95715344/';
const dateFormatter = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<BaseLayout title={post.data.title} description={post.data.description} prose lang={post.data.lang} type="article">
  <nav class="article-nav article-nav--top" aria-label="Article navigation">
    <a href="/blog/">← Back to writing</a>
  </nav>
  <article lang={post.data.lang}>
    <header class="article-header">
      <p class="article-label">Article · {post.data.lang.toUpperCase()}</p>
      <h1>{post.data.title}</h1>
      <p class="description">{post.data.description}</p>
      <p class="meta">{dateFormatter.format(post.data.pubDate)} · Santiago Varela</p>
    </header>
    <div class="article-body"><Content /></div>
  </article>
  <nav class="article-nav article-nav--bottom" aria-label="Article navigation">
    <a href="/blog/">← Back to writing</a>
  </nav>
  <aside class="article-footer">
    <p>Want to discuss this topic?</p>
    <div class="article-footer-actions">
      <a href={`mailto:${email}`}>Email me →</a>
      <a href={linkedInUrl} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
    </div>
  </aside>
</BaseLayout>

<style>
  .article-nav { font-size: 0.9rem; }
  .article-nav--top { margin-top: 2rem; }
  .article-nav--bottom { margin-top: 3rem; }
  .article-nav a { color: var(--color-muted); text-decoration: none; }
  .article-header { padding: clamp(3rem, 8vw, 6rem) 0 3rem; border-bottom: 1px solid var(--color-border); margin-bottom: 3rem; }
  .article-label { color: var(--color-accent); font: 600 0.76rem/1.3 var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; }
  .article-header h1 { font-size: clamp(2.5rem, 7vw, 4.75rem); letter-spacing: -0.055em; line-height: 1; margin: 1.25rem 0 1.5rem; }
  .description { color: var(--color-muted); font-size: 1.12rem; line-height: 1.65; }
  .meta { color: var(--color-muted); font: 500 0.74rem/1.3 var(--font-mono); text-transform: uppercase; letter-spacing: 0.04em; margin: 2rem 0 0; }
  .article-body :global(p), .article-body :global(li) { color: var(--color-prose); }
  .article-body :global(strong) { color: var(--color-text); }
  .article-body :global(a) { overflow-wrap: anywhere; }
  .article-body :global(.article-mid-nav) { margin: 2.5rem 0; font-size: 0.9rem; }
  .article-body :global(.article-mid-nav a) { color: var(--color-muted); text-decoration: none; }
  .article-footer { margin: 1.5rem 0 2rem; padding: 2rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); }
  .article-footer p { color: var(--color-muted); margin: 0 0 0.6rem; }
  .article-footer-actions { display: flex; flex-wrap: wrap; gap: 0.75rem 1.5rem; }
  .article-footer-actions a { font-size: 1.15rem; font-weight: 750; }
</style>
