---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';
import { getPostPath } from '../utils/posts';

const email = 'santiagovarela.86@gmail.com';
const linkedInUrl = 'https://www.linkedin.com/in/santiago-v-95715344/';

const featuredTitles = new Set([
  'DevOps Playground',
  'Coronavirus COVID 19 Tracking Tool',
  'Distributed Messaging System',
  'Operating System Simulation',
]);
const featuredProjects = projects.filter((project) => featuredTitles.has(project.title));
const otherProjects = projects.filter((project) => !featuredTitles.has(project.title));
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
const dateFormatter = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<BaseLayout
  title="Santiago Varela"
  description="Santiago Varela is an IT Operations Manager leading SRE, Change Management, and Release Management, with a background as an Information Systems Engineer."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow"><span class="status-dot"></span> Information Systems Engineer</p>
      <h1>Reliable operations. <br /><span>Practical leadership.</span></h1>
      <p class="hero-lede">
        I lead IT Operations—overseeing Site Reliability, Change Management, and Release
        Management—combining a hands-on engineering background with a methodical approach
        to running dependable, well-governed systems.
      </p>
      <div class="cta-row">
        <a class="button button--primary" href={`mailto:${email}`}>Send me an email <span aria-hidden="true">→</span></a>
        <a class="button button--secondary" href={linkedInUrl} target="_blank" rel="noopener noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
      </div>
    </div>

    <dl class="hero-facts" aria-label="Professional highlights">
      <div><dt>Experience</dt><dd>15+ years</dd></div>
      <div><dt>Focus</dt><dd>Operations & service mgmt</dd></div>
      <div><dt>Credentials</dt><dd>CKA · Azure Expert · ITIL v4</dd></div>
    </dl>
  </section>

  <section class="intro-section section-rule" aria-labelledby="about-heading">
    <p class="section-kicker">01 / About</p>
    <div class="section-content intro-grid">
      <h2 id="about-heading">From electronics to leading IT Operations.</h2>
      <div class="intro-copy">
        <p>
          My career started close to the hardware and moved steadily up the stack: electronics,
          infrastructure administration, operating systems, and cloud platforms.
        </p>
        <p>
          Today I'm an IT Operations Manager, leading the Site Reliability Engineering,
          Change Management, and Release Management teams—the SRE team also owns the
          Incident Management process. That range across layers and disciplines helps me
          look beyond a single team when things go wrong, and push for durable fixes and
          automation that make the next incident less likely.
        </p>
      </div>
    </div>
  </section>

  <section class="section-rule" aria-labelledby="expertise-heading">
    <p class="section-kicker">02 / Expertise</p>
    <div class="section-content">
      <div class="section-heading">
        <h2 id="expertise-heading">What I bring to a team</h2>
        <p>Broad systems experience, applied with a leader's attention to risk, process, and people.</p>
      </div>
      <div class="expertise-grid">
        <article><span class="index">01</span><h3>Operations & service management</h3><p>Leading SRE, Change Management, and Release Management to keep services reliable and changes predictable.</p></article>
        <article><span class="index">02</span><h3>Incident management</h3><p>Owning the incident process end to end—clear escalation, fast resolution, and follow-through on root causes.</p></article>
        <article><span class="index">03</span><h3>Systems thinking</h3><p>A hands-on background across application, operating-system, network, and hardware layers informs how I diagnose and prioritize.</p></article>
      </div>
    </div>
  </section>

  <section id="projects" class="section-rule" aria-labelledby="projects-heading">
    <p class="section-kicker">03 / Projects</p>
    <div class="section-content">
      <div class="section-heading">
        <h2 id="projects-heading">Projects across the stack</h2>
        <p>A curated selection of hands-on work in infrastructure, software, distributed systems, and automation.</p>
      </div>
      <div class="project-grid">
        {featuredProjects.map((project, index) => (
          <ProjectCard project={project} number={index + 1} />
        ))}
      </div>

      <details class="archive">
        <summary>
          <span class="summary-label summary-label--closed">View {otherProjects.length} more projects</span>
          <span class="summary-label summary-label--open">Hide additional projects</span>
          <span class="archive-icon" aria-hidden="true">+</span>
        </summary>
        <div class="project-grid project-grid--archive">
          {otherProjects.map((project, index) => (
            <ProjectCard project={project} number={index + featuredProjects.length + 1} />
          ))}
        </div>
      </details>
    </div>
  </section>

  <section id="writing" class="section-rule" aria-labelledby="writing-heading">
    <p class="section-kicker">04 / Writing</p>
    <div class="section-content">
      <div class="section-heading writing-heading">
        <div><h2 id="writing-heading">Notes from the field</h2><p>Occasional writing about troubleshooting, systems, and ideas worth examining.</p></div>
        <a href="/blog/">All writing <span aria-hidden="true">→</span></a>
      </div>
      <div class="post-list">
        {posts.map((post) => (
          <a class="post-row" href={getPostPath(post)}>
            <span class="post-date">{dateFormatter.format(post.data.pubDate)}</span>
            <span class="post-title">{post.data.title}</span>
            <span class="post-lang">{post.data.lang.toUpperCase()}</span>
            <span class="post-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="contact-section">
    <p class="section-kicker">05 / Contact</p>
    <div class="contact-content">
      <h2>Looking for someone to lead IT Operations?</h2>
      <p>For professional opportunities or conversations about operations and reliability, email is the best way to reach me.</p>
      <a href={`mailto:${email}`}>{email} <span aria-hidden="true">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { min-height: 38rem; display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(15rem, 0.55fr); align-items: center; gap: clamp(3rem, 8vw, 7rem); padding: clamp(5rem, 10vw, 8rem) 0; }
  .eyebrow, .section-kicker { color: var(--color-accent); font: 600 0.76rem/1.3 var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; }
  .eyebrow { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 1.35rem; }
  .status-dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: var(--color-success); box-shadow: 0 0 0 0.25rem var(--color-success-soft); }
  .hero h1 { font-size: clamp(3rem, 7vw, 6.25rem); letter-spacing: -0.065em; line-height: 0.94; max-width: 11ch; margin-bottom: 1.75rem; }
  .hero h1 span { color: var(--color-muted); }
  .hero-lede { color: var(--color-muted); font-size: clamp(1.05rem, 1.4vw, 1.22rem); line-height: 1.7; max-width: 42rem; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
  .hero-facts { margin: 0; border-top: 1px solid var(--color-border); }
  .hero-facts div { padding: 1.15rem 0; border-bottom: 1px solid var(--color-border); }
  .hero-facts dt { color: var(--color-muted); font: 500 0.72rem/1.3 var(--font-mono); text-transform: uppercase; letter-spacing: 0.07em; }
  .hero-facts dd { margin: 0.3rem 0 0; font-weight: 700; }
  .section-rule { display: grid; grid-template-columns: 11rem minmax(0, 1fr); gap: 2rem; padding: 5rem 0; border-top: 1px solid var(--color-border); scroll-margin-top: 1rem; }
  .section-kicker { margin: 0; }
  .section-content h2, .contact-content h2 { font-size: clamp(2rem, 4vw, 3.35rem); letter-spacing: -0.045em; max-width: 16ch; margin: 0; }
  .intro-grid { display: grid; grid-template-columns: minmax(15rem, 0.8fr) minmax(18rem, 1.2fr); gap: clamp(2rem, 6vw, 6rem); align-items: start; }
  .intro-copy { color: var(--color-muted); font-size: 1.08rem; max-width: 40rem; }
  .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 2rem; margin-bottom: 2.5rem; }
  .section-heading > p, .writing-heading > div > p { color: var(--color-muted); max-width: 31rem; margin: 0; }
  .expertise-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .expertise-grid article { padding: 1.75rem 1.5rem 2rem; border-right: 1px solid var(--color-border); }
  .expertise-grid article:first-child { padding-left: 0; }
  .expertise-grid article:last-child { border-right: 0; }
  .expertise-grid .index { color: var(--color-accent); font: 500 0.75rem/1 var(--font-mono); }
  .expertise-grid h3 { font-size: 1.15rem; margin: 2.5rem 0 0.65rem; }
  .expertise-grid p { color: var(--color-muted); font-size: 0.93rem; margin: 0; }
  .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); border-top: 1px solid var(--color-border); border-left: 1px solid var(--color-border); }
  .archive { margin-top: 1.25rem; border-bottom: 1px solid var(--color-border); }
  .archive summary { display: flex; justify-content: space-between; cursor: pointer; padding: 1.1rem 0; font-weight: 700; list-style: none; }
  .archive summary::-webkit-details-marker { display: none; }
  .summary-label--open { display: none; }
  .archive-icon { transition: transform 0.15s ease; }
  .archive[open] .summary-label--closed { display: none; }
  .archive[open] .summary-label--open { display: inline; }
  .archive[open] .archive-icon { transform: rotate(45deg); }
  .project-grid--archive { margin-bottom: 1.25rem; }
  .writing-heading > div { display: contents; }
  .writing-heading > a { white-space: nowrap; font-weight: 700; text-decoration: none; }
  .post-list { border-top: 1px solid var(--color-border); }
  .post-row { display: grid; grid-template-columns: 8rem minmax(0, 1fr) 2rem 1.5rem; gap: 1.25rem; align-items: center; padding: 1.35rem 0; border-bottom: 1px solid var(--color-border); color: var(--color-text); text-decoration: none; }
  .post-date, .post-lang { color: var(--color-muted); font: 500 0.73rem/1 var(--font-mono); text-transform: uppercase; }
  .post-title { font-weight: 700; }
  .post-arrow { color: var(--color-accent); font-size: 1.2rem; transition: transform 0.15s ease; }
  .post-row:hover .post-arrow { transform: translateX(0.25rem); }
  .contact-section { margin: 2rem 0 5rem; padding: clamp(2rem, 5vw, 4rem); background: var(--color-text); color: var(--color-bg); border-radius: var(--radius-lg); display: grid; grid-template-columns: 9rem minmax(0, 1fr); gap: 2rem; scroll-margin-top: 1rem; }
  .contact-section .section-kicker { color: var(--color-contact-accent); }
  .contact-content p { color: var(--color-contact-muted); max-width: 38rem; margin: 1.25rem 0 2rem; }
  .contact-content a { color: var(--color-bg); font-weight: 750; font-size: clamp(1rem, 2.5vw, 1.35rem); text-underline-offset: 0.35rem; }
  @media (max-width: 52rem) {
    .hero { grid-template-columns: 1fr; min-height: auto; gap: 3.5rem; }
    .hero-facts { display: grid; grid-template-columns: repeat(3, 1fr); }
    .hero-facts div { border-right: 1px solid var(--color-border); padding: 1rem; }
    .hero-facts div:first-child { padding-left: 0; }
    .hero-facts div:last-child { border-right: 0; }
    .section-rule { grid-template-columns: 1fr; gap: 1.75rem; }
    .intro-grid { grid-template-columns: 1fr; }
    .section-heading { align-items: start; flex-direction: column; }
    .expertise-grid { grid-template-columns: 1fr; }
    .expertise-grid article, .expertise-grid article:first-child { padding: 1.5rem 0; border-right: 0; border-bottom: 1px solid var(--color-border); }
    .expertise-grid article:last-child { border-bottom: 0; }
    .expertise-grid h3 { margin-top: 1.25rem; }
  }
  @media (max-width: 40rem) {
    .hero { padding: 4.5rem 0; }
    .hero h1 { font-size: clamp(2.9rem, 15vw, 4.5rem); }
    .hero-facts { grid-template-columns: 1fr; }
    .hero-facts div, .hero-facts div:first-child { padding: 0.9rem 0; border-right: 0; }
    .section-rule { padding: 4rem 0; }
    .project-grid { grid-template-columns: 1fr; }
    .post-row { grid-template-columns: 1fr auto; gap: 0.45rem 1rem; }
    .post-date { grid-column: 1; }
    .post-title { grid-column: 1; }
    .post-lang { grid-column: 2; grid-row: 1; }
    .post-arrow { grid-column: 2; grid-row: 2; }
    .contact-section { grid-template-columns: 1fr; padding: 2rem; margin-bottom: 3rem; }
  }
</style>
