---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The requested page could not be found.">
  <section class="not-found">
    <p>404 / Not found</p>
    <h1>This route reached a dead end.</h1>
    <a class="button button--primary" href="/">Return home →</a>
  </section>
</BaseLayout>

<style>
  .not-found { min-height: 65vh; display: grid; place-content: center; justify-items: start; }
  .not-found p { color: var(--color-accent); font: 600 0.76rem/1.3 var(--font-mono); text-transform: uppercase; letter-spacing: 0.08em; }
  .not-found h1 { font-size: clamp(2.75rem, 8vw, 5.5rem); max-width: 11ch; letter-spacing: -0.06em; margin: 1rem 0 2rem; }
</style>
