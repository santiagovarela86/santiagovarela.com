---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, year, description, technologies, links } = project.data;
---

<BaseLayout title={title} description={description} prose>
  <p class="back"><a href="/projects/">← All projects</a></p>
  <article>
    <header class="project-header">
      <p class="project-label">Project · {year}</p>
      <h1>{title}</h1>
      <p class="description">{description}</p>
    </header>

    <div class="project-facts">
      <section aria-labelledby="technologies-heading">
        <h2 id="technologies-heading">Technologies</h2>
        <ul class="tech-list">
          {technologies.map((technology) => <li>{technology}</li>)}
        </ul>
      </section>

      <section aria-labelledby="links-heading">
        <h2 id="links-heading">Project links</h2>
        {links.length > 0 ? (
          <ul class="link-list">
            {links.map((link) => (
              <li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.label} <span aria-hidden="true">↗</span></a></li>
            ))}
          </ul>
        ) : <p>Source code is not publicly available.</p>}
      </section>
    </div>

    <div class="project-body"><Content /></div>
  </article>
</BaseLayout>

<style>
  .back { margin-top: 2rem; font-size: 0.9rem; }
  .back a { color: var(--color-muted); text-decoration: none; }
  .project-header { padding: clamp(3rem, 8vw, 6rem) 0 3rem; border-bottom: 1px solid var(--color-border); }
  .project-label { color: var(--color-accent); font: 600 0.76rem/1.3 var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; }
  .project-header h1 { font-size: clamp(2.5rem, 7vw, 4.75rem); letter-spacing: -0.055em; line-height: 1; margin: 1.25rem 0 1.5rem; max-width: 18ch; }
  .description { color: var(--color-muted); font-size: 1.12rem; line-height: 1.65; max-width: 48rem; }
  .project-facts { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(14rem, 0.75fr); gap: clamp(2rem, 6vw, 6rem); padding: 2.5rem 0; border-bottom: 1px solid var(--color-border); }
  .project-facts h2 { font: 600 0.76rem/1.3 var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1rem; }
  .tech-list, .link-list { list-style: none; padding: 0; margin: 0; }
  .tech-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tech-list li { padding: 0.38rem 0.65rem; border: 1px solid var(--color-border); border-radius: 999px; color: var(--color-muted); font: 500 0.72rem/1 var(--font-mono); }
  .link-list { display: flex; flex-direction: column; gap: 0.55rem; }
  .project-facts a { font-weight: 650; text-decoration: none; }
  .project-facts p { color: var(--color-muted); margin: 0; }
  .project-body { max-width: 48rem; padding: 3rem 0 5rem; }
  .project-body :global(p), .project-body :global(li) { color: var(--color-prose); }
  @media (max-width: 42rem) { .project-facts { grid-template-columns: 1fr; } }
</style>
