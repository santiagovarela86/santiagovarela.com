---
const email = 'santiagovarela.86@gmail.com';
const linkedInUrl = 'https://www.linkedin.com/in/santiago-v-95715344/';
const githubUrl = 'https://github.com/santiagovarela86';
---

<footer>
  <div>
    <p class="footer-name">Santiago Varela</p>
    <p class="footer-role">Information Systems Engineer</p>
  </div>
  <div class="footer-meta">
    <p><a href={`mailto:${email}`}>Email</a> <span aria-hidden="true">·</span> <a href={linkedInUrl} target="_blank" rel="noopener noreferrer">Message on LinkedIn</a> <span aria-hidden="true">·</span> <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a></p>
    <p class="copyright">&copy; {new Date().getFullYear()}</p>
  </div>
</footer>

<style>
  footer {
    max-width: var(--measure-wide);
    margin: 0 auto;
    padding: 1.75rem var(--page-gutter) 2.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.9rem;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  footer p {
    margin: 0;
  }

  .footer-name {
    color: var(--color-text);
    font-weight: 700;
  }

  .footer-role {
    margin-top: 0.2rem;
  }

  .footer-meta {
    text-align: right;
  }

  .copyright {
    margin-top: 0.2rem;
  }

  @media (max-width: 34rem) {
    footer {
      flex-direction: column;
      gap: 1rem;
    }

    .footer-meta {
      text-align: left;
    }
  }
</style>
