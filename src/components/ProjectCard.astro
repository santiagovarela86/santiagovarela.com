---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  number: number;
}

const { project, number } = Astro.props;
const { title, year, description, technologies, links } = project.data;
const projectPath = `/projects/${project.id}/`;
---

<article class="project-card">
  <div class="project-meta">
    <span>{year}</span>
    <span>{String(number).padStart(2, '0')}</span>
  </div>
  <h3><a href={projectPath}>{title}</a></h3>
  <p>{description}</p>
  <ul class="tech-list" aria-label={`Technologies used for ${title}`}>
    {technologies.map((technology) => <li>{technology}</li>)}
  </ul>
  <div class="project-links">
    <a href={projectPath}>Read project <span aria-hidden="true">→</span></a>
    {links.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer">
          {link.label} <span aria-hidden="true">↗</span>
        </a>
    ))}
  </div>
</article>

<style>
  .project-card {
    min-height: 24rem;
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    color: var(--color-muted);
    font: 500 0.73rem/1 var(--font-mono);
  }

  h3 {
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    margin: 2.4rem 0 0.8rem;
    max-width: 19ch;
  }

  h3 a {
    color: inherit;
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  .project-card > p {
    color: var(--color-muted);
    font-size: 0.94rem;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    padding: 0;
    margin: auto 0 1.5rem;
  }

  .tech-list li {
    padding: 0.28rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-muted);
    font: 500 0.7rem/1 var(--font-mono);
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .project-links a {
    font-size: 0.85rem;
    font-weight: 650;
    text-decoration: none;
  }

  @media (max-width: 40rem) {
    .project-card {
      min-height: 21rem;
    }
  }
</style>
